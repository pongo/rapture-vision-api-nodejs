{
  "name": "rapture-vision-api-nodejs",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "exports": "./index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test src/**/*.test.js tests/integration/mock/**/*.test.js",
    "test:bail": "node --test --test-reporter=@reporters/bail --test-reporter-destination=stderr --test-reporter=spec --test-reporter-destination=stdout",
    "test:watch": "node --test --watch",
    "test:min": "node --test --test-reporter=reporter-minimal --test-reporter-destination=stdout",
    "test:min:my": "node --test --test-reporter=./tests/utils/reporter-minimal.js",
    "test:pretty": "node --test --test-reporter=@voxpelli/node-test-pretty-reporter",
    "test:dot": "node --test --test-reporter=@synap-ac/node-dot-extra-reporter",
    "coverage": "c8 --all --src src -r text -r html node --test src/**/*.test.js tests/integration/mock/**/*.test.js && echo Report: coverage/index.html",
    "installation": "npm i --include=optional --include=peer --omit=dev",
    "lint:oxlint": "oxlint --tsconfig=./tsconfig.json --disable-react-plugin --import-plugin  --promise-plugin --node-plugin --security-plugin src tests/integration cli.js index.js eslint.config.js",
    "lint:biome": "biome lint",
    "lint": "eslint"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.2"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.21.0",
    "@vladmandic/face-api": "1.7.3",
    "canvas": "^2.11.2",
    "axios": "^1.6.8",
    "cheerio": "^1.1.2",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "jwt-decode": "^4.0.0",
    "keyv": "^5.0.3",
    "keyv-file": "^5.0.3",
    "p-timeout": "^6.1.3",
    "write-json-file": "^6.0.0",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@reporters/bail": "^1.2.1",
    "@synap-ac/node-dot-extra-reporter": "^1.3.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@voxpelli/node-test-pretty-reporter": "^1.1.2",
    "eslint": "^9.14.0",
    "eslint-plugin-n": "^17.13.1",
    "eslint-plugin-unicorn": "^56.0.0",
    "express-request-mock": "^4.0.0",
    "globals": "^15.12.0",
    "light-my-request": "^6.3.0",
    "prettier": "^3.3.3",
    "reporter-minimal": "^0.0.1"
  },
  "overrides": {
    "node-fetch@2.x": {
      "whatwg-url": "14.x"
    }
  },
  "_moduleAliases": {
    "src": "./src",
    "tests": "./tests"
  }
}
